<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Circuitos Eléctricos — Prácticas con Tinkercad | 2º ESO</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Outfit:wght@300;400;600;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --surface2: #1c2330;
    --border: #30363d;
    --accent: #f0b429;
    --accent2: #58a6ff;
    --accent3: #3fb950;
    --accent4: #ff7b72;
    --accent5: #d2a8ff;
    --text: #e6edf3;
    --muted: #8b949e;
    --mono: 'Space Mono', monospace;
    --sans: 'Outfit', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.7;
  }

  /* ── GRID BACKGROUND ── */
  body::before {
    content: '';
    position: fixed; inset: 0; z-index: 0;
    background-image:
      linear-gradient(rgba(240,180,41,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(240,180,41,.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
  }

  .page { max-width: 920px; margin: 0 auto; padding: 40px 24px 80px; position: relative; z-index: 1; }

  /* ── COVER ── */
  .cover {
    text-align: center;
    padding: 80px 0 60px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 60px;
    position: relative;
  }
  .cover::after {
    content: '';
    position: absolute; bottom: -1px; left: 50%; transform: translateX(-50%);
    width: 120px; height: 2px; background: var(--accent);
  }
  .cover-tag {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 4px 14px;
    border-radius: 2px;
    margin-bottom: 28px;
    animation: fadeUp .6s ease both;
  }
  .cover h1 {
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 900;
    letter-spacing: -.02em;
    line-height: 1.1;
    animation: fadeUp .6s .1s ease both;
  }
  .cover h1 span { color: var(--accent); }
  .cover-sub {
    font-size: 1.1rem;
    color: var(--muted);
    margin-top: 16px;
    animation: fadeUp .6s .2s ease both;
  }
  .cover-chips {
    display: flex; flex-wrap: wrap; gap: 10px;
    justify-content: center; margin-top: 36px;
    animation: fadeUp .6s .3s ease both;
  }
  .chip {
    font-family: var(--mono);
    font-size: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 6px 14px;
    border-radius: 3px;
    color: var(--muted);
  }
  .chip b { color: var(--accent2); font-weight: 400; }

  /* ── STUDENT DATA ── */
  .student-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
    margin: 40px 0;
  }
  .field {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px 20px;
  }
  .field label {
    display: block;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .field-line {
    border-bottom: 1px solid var(--border);
    height: 28px;
  }

  /* ── SECTION / THEORY ── */
  .section-header {
    display: flex; align-items: center; gap: 16px;
    margin: 56px 0 28px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .section-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: .1em;
    white-space: nowrap;
  }
  .section-header h2 {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -.01em;
  }

  /* ── ACTIVITY CARD ── */
  .activity {
    margin: 48px 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    break-inside: avoid;
  }
  .activity-header {
    padding: 22px 28px;
    display: flex; align-items: center; gap: 18px;
    border-bottom: 1px solid var(--border);
  }
  .act-num {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--bg);
    background: var(--accent);
    padding: 5px 12px;
    border-radius: 3px;
    font-weight: 700;
    white-space: nowrap;
  }
  .act-num.blue { background: var(--accent2); }
  .act-num.green { background: var(--accent3); }
  .act-num.red { background: var(--accent4); }
  .act-num.purple { background: var(--accent5); }
  .activity-header h3 {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -.01em;
  }
  .activity-body {
    padding: 28px;
    background: var(--surface);
    display: flex; flex-direction: column; gap: 20px;
  }

  /* ── INFO BOX ── */
  .info-box {
    border-left: 3px solid var(--accent2);
    background: var(--surface2);
    padding: 16px 20px;
    border-radius: 0 6px 6px 0;
    font-size: 14px;
  }
  .info-box.yellow { border-color: var(--accent); }
  .info-box.green { border-color: var(--accent3); }
  .info-box.red { border-color: var(--accent4); }
  .info-box.purple { border-color: var(--accent5); }
  .info-box strong { color: var(--accent2); display: block; margin-bottom: 8px; font-family: var(--mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; }
  .info-box.yellow strong { color: var(--accent); }
  .info-box.green strong { color: var(--accent3); }
  .info-box.red strong { color: var(--accent4); }
  .info-box.purple strong { color: var(--accent5); }
  .info-box ul { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .info-box ul li::before { content: '→ '; color: var(--muted); font-family: var(--mono); }

  /* ── FORMULA ── */
  .formula {
    background: #0d1117;
    border: 1px solid var(--accent5);
    border-radius: 6px;
    padding: 16px 24px;
    text-align: center;
    font-family: var(--mono);
    font-size: 1.05rem;
    color: var(--accent5);
    letter-spacing: .05em;
  }

  /* ── TABLE ── */
  .tbl-wrap { overflow-x: auto; border-radius: 6px; border: 1px solid var(--border); }
  table {
    width: 100%; border-collapse: collapse;
    font-size: 13px;
  }
  thead th {
    background: #1f2937;
    color: var(--accent2);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid var(--border);
  }
  tbody tr:nth-child(odd) td { background: var(--surface2); }
  tbody tr:nth-child(even) td { background: var(--surface); }
  tbody td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    color: var(--text);
  }
  tbody tr:last-child td { border-bottom: none; }
  .td-input {
    background: rgba(255,255,255,.03) !important;
    border-left: 1px dashed var(--border);
  }

  /* ── DRAW BOX ── */
  .draw-box {
    border: 1px dashed var(--border);
    border-radius: 6px;
    background: rgba(255,255,255,.015);
    position: relative;
    min-height: 200px;
    display: flex; align-items: center; justify-content: center;
  }
  .draw-box-label {
    position: absolute; top: 14px; left: 18px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--accent2);
    opacity: .7;
  }
  .draw-box-inner {
    text-align: center; color: var(--muted); font-size: 13px;
  }
  .draw-icon { font-size: 2rem; display: block; margin-bottom: 8px; opacity: .3; }

  /* ── ANSWER BOX ── */
  .answer-box {
    border: 1px solid var(--border);
    border-radius: 6px;
    background: rgba(255,255,255,.02);
  }
  .answer-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
  }
  .answer-lines { padding: 8px 16px; }
  .answer-line {
    height: 34px;
    border-bottom: 1px solid rgba(255,255,255,.07);
  }
  .answer-line:last-child { border-bottom: none; }

  /* ── QUESTION ── */
  .question {
    background: rgba(240,180,41,.08);
    border: 1px solid rgba(240,180,41,.25);
    border-radius: 6px;
    padding: 14px 18px;
    font-size: 14px;
  }
  .question::before {
    content: '❓ PREGUNTA — ';
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .1em;
    color: var(--accent);
    font-weight: 700;
  }

  /* ── STEPS ── */
  .steps { display: flex; flex-direction: column; gap: 10px; counter-reset: step; }
  .step {
    display: flex; gap: 14px; align-items: flex-start;
    counter-increment: step;
    font-size: 14px;
  }
  .step::before {
    content: counter(step);
    min-width: 28px; height: 28px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent2);
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ── BULLETS ── */
  .bullets { display: flex; flex-direction: column; gap: 8px; }
  .bullet-item {
    display: flex; gap: 12px; align-items: flex-start;
    font-size: 14px;
  }
  .bullet-item::before {
    content: '▸';
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* ── TWO COL ── */
  .two-col {
    display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
  }
  .col-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 16px;
  }
  .col-card h4 {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--accent2);
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .col-card.yellow h4 { color: var(--accent); }
  .col-card.green h4 { color: var(--accent3); }
  .col-card p { font-size: 13px; color: var(--muted); }

  /* ── RUBRIC ── */
  .rubric-grid { display: grid; gap: 2px; }
  .rubric-row { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 1fr; gap: 2px; }
  .rubric-cell {
    background: var(--surface);
    padding: 12px 14px;
    font-size: 12.5px;
    border-radius: 2px;
  }
  .rubric-head { background: #1f2937; }
  .rubric-head .rubric-cell {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--accent2);
    background: #1f2937;
  }
  .score-4 { border-left: 3px solid var(--accent3); }
  .score-3 { border-left: 3px solid var(--accent2); }
  .score-2 { border-left: 3px solid var(--accent); }
  .score-1 { border-left: 3px solid var(--accent4); }

  /* ── PRINT ── */
  .print-btn {
    position: fixed;
    bottom: 32px; right: 32px;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 12px 22px;
    border: none; border-radius: 4px;
    cursor: pointer;
    font-weight: 700;
    box-shadow: 0 8px 24px rgba(240,180,41,.4);
    z-index: 100;
    transition: transform .15s, box-shadow .15s;
  }
  .print-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(240,180,41,.5); }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .activity { animation: fadeUp .5s ease both; }

  /* ── PRINT STYLES ── */
  @media print {
    body { background: #fff; color: #111; }
    body::before { display: none; }
    .print-btn { display: none; }
    :root {
      --bg: #fff; --surface: #f8f8f8; --surface2: #f0f0f0;
      --border: #ddd; --text: #111; --muted: #555;
      --accent: #d97706; --accent2: #2563eb; --accent3: #16a34a;
      --accent4: #dc2626; --accent5: #7c3aed;
    }
    .formula { color: #7c3aed; border-color: #7c3aed; }
    .activity { break-inside: avoid; }
    .draw-box { min-height: 180px; }
  }

  @media (max-width: 600px) {
    .two-col { grid-template-columns: 1fr; }
    .rubric-row { grid-template-columns: 1fr 1fr; }
    .student-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>
<div class="page">

  <!-- COVER -->
  <header class="cover">
    <div class="cover-tag">Tecnología — 2.º E.S.O.</div>
    <h1>Circuitos <span>Eléctricos</span></h1>
    <p class="cover-sub">Prácticas con Tinkercad · 10 actividades</p>
    <div class="cover-chips">
      <span class="chip"><b>⚡</b> Ley de Ohm</span>
      <span class="chip"><b>🔌</b> Serie &amp; Paralelo</span>
      <span class="chip"><b>📏</b> Multímetro</span>
      <span class="chip"><b>☀️</b> Panel Solar</span>
      <span class="chip"><b>💡</b> LEDs</span>
      <span class="chip"><b>⚙️</b> Motor DC</span>
      <span class="chip"><b>🔆</b> LDR</span>
    </div>
  </header>

  <!-- STUDENT DATA -->
  <div class="student-grid">
    <div class="field"><label>Nombre completo</label><div class="field-line"></div></div>
    <div class="field"><label>Curso y grupo</label><div class="field-line"></div></div>
    <div class="field"><label>Fecha</label><div class="field-line"></div></div>
    <div class="field"><label>Nota</label><div class="field-line"></div></div>
  </div>

  <!-- ========= INTRODUCCIÓN TEÓRICA ========= -->
  <div class="section-header">
    <span class="section-num">// 00</span>
    <h2>Introducción Teórica</h2>
  </div>

  <div class="info-box yellow">
    <strong>Magnitudes eléctricas fundamentales</strong>
    <ul>
      <li><b>Voltaje (V)</b> — Diferencia de potencial, en voltios (V). Es la "presión" que mueve la corriente.</li>
      <li><b>Intensidad (I)</b> — Cantidad de corriente que fluye, en amperios (A).</li>
      <li><b>Resistencia (R)</b> — Oposición al paso de la corriente, en ohmios (Ω).</li>
      <li><b>Potencia (P)</b> — Energía consumida por unidad de tiempo, en vatios (W). P = V · I</li>
    </ul>
  </div>

  <div class="formula" style="margin-top:20px;">
    LEY DE OHM &nbsp;&nbsp; V = I × R &nbsp;&nbsp;|&nbsp;&nbsp; I = V / R &nbsp;&nbsp;|&nbsp;&nbsp; R = V / I
  </div>

  <div class="two-col" style="margin-top:20px;">
    <div class="col-card">
      <h4>Circuito en Serie</h4>
      <p>La corriente (I) es igual en todos los componentes.<br>Los voltajes se suman: V = V₁ + V₂ + …<br>R = R₁ + R₂ + …</p>
    </div>
    <div class="col-card green">
      <h4>Circuito en Paralelo</h4>
      <p>El voltaje es igual en cada rama.<br>Las corrientes se suman: I = I₁ + I₂ + …<br>1/R = 1/R₁ + 1/R₂ + …</p>
    </div>
  </div>

  <div class="info-box" style="margin-top:20px;">
    <strong>El multímetro en Tinkercad</strong>
    <ul>
      <li><b>Voltímetro:</b> se conecta en PARALELO con el componente. Selector en V DC.</li>
      <li><b>Amperímetro:</b> se conecta en SERIE. El circuito pasa <em>a través</em> del multímetro. Selector en A DC.</li>
      <li><b>Ohmímetro:</b> circuito apagado, se mide directamente la resistencia.</li>
    </ul>
  </div>

  <!-- COLOR CODE VISUAL TABLE -->
  <div style="margin-top:20px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:20px 24px;">
    <div style="font-family:var(--mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--accent5);margin-bottom:14px;">
      ▸ Código de colores de resistencias (4 bandas)
    </div>
    <div style="font-size:13px;color:var(--muted);margin-bottom:18px;">
      Las resistencias llevan 4 bandas de color: las dos primeras son los dígitos, la tercera el multiplicador y la cuarta la tolerancia.
    </div>

    <!-- RESISTOR DIAGRAM -->
    <div style="display:flex;align-items:center;justify-content:center;margin-bottom:10px;gap:0;">
      <div style="width:60px;height:12px;background:linear-gradient(90deg,#555,#a0522d);border-radius:6px 0 0 6px;"></div>
      <div style="width:160px;height:32px;background:#c8a96e;border-radius:4px;display:flex;align-items:center;justify-content:space-around;padding:0 16px;box-shadow:0 2px 8px rgba(0,0,0,.4);">
        <div style="width:12px;height:32px;background:#f5a623;border-radius:1px;"></div>
        <div style="width:12px;height:32px;background:#7c3aed;border-radius:1px;"></div>
        <div style="width:12px;height:32px;background:#dc2626;border-radius:1px;"></div>
        <div style="width:8px;"></div>
        <div style="width:12px;height:32px;background:linear-gradient(135deg,#d4a017,#f5d060,#d4a017);border-radius:1px;"></div>
      </div>
      <div style="width:60px;height:12px;background:linear-gradient(90deg,#a0522d,#555);border-radius:0 6px 6px 0;"></div>
    </div>
    <div style="display:flex;justify-content:center;gap:0;font-family:var(--mono);font-size:10px;color:var(--muted);margin-bottom:20px;text-align:center;">
      <span style="width:80px;">1.ª banda<br><span style="color:var(--accent)">1.er dígito</span></span>
      <span style="width:80px;">2.ª banda<br><span style="color:var(--accent)">2.º dígito</span></span>
      <span style="width:80px;">3.ª banda<br><span style="color:var(--accent)">multiplicador</span></span>
      <span style="width:80px;">4.ª banda<br><span style="color:var(--accent)">tolerancia</span></span>
    </div>

    <!-- COLOR TABLE -->
    <div class="tbl-wrap">
      <table>
        <thead>
          <tr>
            <th>Color</th>
            <th>Muestra</th>
            <th>Dígito (bandas 1 y 2)</th>
            <th>Multiplicador (banda 3)</th>
            <th>Tolerancia (banda 4)</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>Negro</td><td><div style="width:32px;height:18px;background:#1a1a1a;border-radius:3px;border:1px solid #444;"></div></td><td>0</td><td>× 1</td><td>—</td></tr>
          <tr><td>Marrón</td><td><div style="width:32px;height:18px;background:#7b3f00;border-radius:3px;"></div></td><td>1</td><td>× 10</td><td>±1%</td></tr>
          <tr><td>Rojo</td><td><div style="width:32px;height:18px;background:#dc2626;border-radius:3px;"></div></td><td>2</td><td>× 100</td><td>±2%</td></tr>
          <tr><td>Naranja</td><td><div style="width:32px;height:18px;background:#ea580c;border-radius:3px;"></div></td><td>3</td><td>× 1.000</td><td>—</td></tr>
          <tr><td>Amarillo</td><td><div style="width:32px;height:18px;background:#f5a623;border-radius:3px;"></div></td><td>4</td><td>× 10.000</td><td>—</td></tr>
          <tr><td>Verde</td><td><div style="width:32px;height:18px;background:#16a34a;border-radius:3px;"></div></td><td>5</td><td>× 100.000</td><td>±0,5%</td></tr>
          <tr><td>Azul</td><td><div style="width:32px;height:18px;background:#2563eb;border-radius:3px;"></div></td><td>6</td><td>× 1.000.000</td><td>±0,25%</td></tr>
          <tr><td>Violeta</td><td><div style="width:32px;height:18px;background:#7c3aed;border-radius:3px;"></div></td><td>7</td><td>—</td><td>±0,1%</td></tr>
          <tr><td>Gris</td><td><div style="width:32px;height:18px;background:#6b7280;border-radius:3px;"></div></td><td>8</td><td>—</td><td>—</td></tr>
